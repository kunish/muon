{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*" },
        { "url": "https://*:*" },
        { "url": "http://*" },
        { "url": "https://*" }
      ]
    }
  ]
}
