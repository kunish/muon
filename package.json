{
  "name": "muon",
  "type": "module",
  "version": "1.0.1",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "description": "A modern, fast Matrix chat client built with Tauri and Vue 3",
  "author": "Muon Contributors",
  "license": "MIT",
  "homepage": "https://github.com/kunish/muon#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kunish/muon.git"
  },
  "bugs": {
    "url": "https://github.com/kunish/muon/issues"
  },
  "keywords": [
    "matrix",
    "chat",
    "tauri",
    "vue",
    "desktop",
    "encrypted",
    "messenger"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint .",
    "type-check": "vue-tsc --noEmit",
    "services:up": "bash docker/start.sh",
    "services:down": "docker compose -f docker/docker-compose.yml down",
    "services:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test": "pnpm test:unit && pnpm test:e2e"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-query": "^5.92.10",
    "@tanstack/vue-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-mention": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@tiptap/vue-3": "^3.20.4",
    "@vueuse/core": "^14.2.1",
    "@vueuse/gesture": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compressorjs": "^1.2.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dompurify": "^3.3.3",
    "idb-keyval": "^6.2.2",
    "ky": "^1.14.3",
    "livekit-client": "^2.17.3",
    "lottie-web": "^5.13.0",
    "lucide-vue-next": "^0.577.0",
    "matrix-js-sdk": "^41.1.0",
    "mitt": "^3.0.1",
    "nanoid": "^5.1.7",
    "pinia": "^3.0.4",
    "plyr": "^3.8.4",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "viewerjs": "^1.11.7",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
    "vue-sonner": "^2.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "jsdom": "^29.0.0",
    "msw": "^2.12.13",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ]
  }
}
